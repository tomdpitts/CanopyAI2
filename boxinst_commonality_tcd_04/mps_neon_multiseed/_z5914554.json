{"created": "2022-01-28T21:32:11.781629+00:00", "modified": "2022-01-29T01:48:53.326368+00:00", "id": 5914554, "conceptrecid": "3459802", "doi": "10.5281/zenodo.5914554", "conceptdoi": "10.5281/zenodo.3459802", "doi_url": "https://doi.org/10.5281/zenodo.5914554", "metadata": {"title": "Data for the NeonTreeEvaluation Benchmark", "doi": "10.5281/zenodo.5914554", "publication_date": "2022-01-27", "description": "<p>This dataset is the data files for the NeonTreeEvaluation Benchmark for individual tree detection from airborne imagery. For each geographic site, given by the NEON four letter code (e.g HARV -&gt; Harvard Forest), there are up to 4 files: a RGB image, a LiDAR tile, and a 426 band hyperpspectral file, and a 1m canopy height file.&nbsp;For more information on the benchmark, and the corresponding R package, see&nbsp;<a href=\"https://github.com/weecology/NeonTreeEvaluation_package\">https://github.com/weecology/NeonTreeEvaluation_package</a>&nbsp;</p>\n\n<p>Training.zip and Evaluation.zip both have the same folder structure with RGB, Hyperspectral, LiDAR and CHM folders. All annotations are in the annotation.zip. Not all files in the evaluation.zip have corresponding annotations. We have included these to allow users to test their approaches, annotate new data, or use semi-supervised methods.</p>", "access_right": "open", "creators": [{"name": "Ben Weinstein", "affiliation": "University of Florida", "orcid": "0000-0002-2176-7935"}, {"name": "Sergio Marconi", "affiliation": "University of Florida"}, {"name": "Ethan White", "affiliation": "University of Florida"}], "keywords": ["trees", "machine learning", "LiDAR", "Hyperspectral", "RGB", "object detection"], "version": "0.2.2", "resource_type": {"title": "Dataset", "type": "dataset"}, "license": {"id": "cc-by-4.0"}, "relations": {"version": [{"index": 6, "is_last": true, "parent": {"pid_type": "recid", "pid_value": "3459802"}}]}}, "title": "Data for the NeonTreeEvaluation Benchmark", "links": {"self": "https://zenodo.org/api/records/5914554", "self_html": "https://zenodo.org/records/5914554", "preview_html": "https://zenodo.org/records/5914554?preview=1", "doi": "https://doi.org/10.5281/zenodo.5914554", "self_doi": "https://doi.org/10.5281/zenodo.5914554", "self_doi_html": "https://zenodo.org/doi/10.5281/zenodo.5914554", "reserve_doi": "https://zenodo.org/api/records/5914554/draft/pids/doi", "parent": "https://zenodo.org/api/records/3459802", "parent_html": "https://zenodo.org/records/3459802", "parent_doi": "https://doi.org/10.5281/zenodo.3459802", "parent_doi_html": "https://zenodo.org/doi/10.5281/zenodo.3459802", "self_iiif_manifest": "https://zenodo.org/api/iiif/record:5914554/manifest", "self_iiif_sequence": "https://zenodo.org/api/iiif/record:5914554/sequence/default", "files": "https://zenodo.org/api/records/5914554/files", "media_files": "https://zenodo.org/api/records/5914554/media-files", "archive": "https://zenodo.org/api/records/5914554/files-archive", "archive_media": "https://zenodo.org/api/records/5914554/media-files-archive", "latest": "https://zenodo.org/api/records/5914554/versions/latest", "latest_html": "https://zenodo.org/records/5914554/latest", "versions": "https://zenodo.org/api/records/5914554/versions", "draft": "https://zenodo.org/api/records/5914554/draft", "access_links": "https://zenodo.org/api/records/5914554/access/links", "access_grants": "https://zenodo.org/api/records/5914554/access/grants", "access_users": "https://zenodo.org/api/records/5914554/access/users", "access_request": "https://zenodo.org/api/records/5914554/access/request", "access": "https://zenodo.org/api/records/5914554/access", "communities": "https://zenodo.org/api/records/5914554/communities", "communities-suggestions": "https://zenodo.org/api/records/5914554/communities-suggestions", "request_deletion": "https://zenodo.org/api/records/5914554/request-deletion", "file_modification": "https://zenodo.org/api/records/5914554/file-modification", "quota_increase": "https://z